@model List<BusinessObjects.Models.Interview>
@{
    Layout = "~/Views/Shared/_LayoutSidebar.cshtml";
}


<div class="main-content" id="mainContent">

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Total</span>
                <svg class="stat-icon" viewBox="0 0 24 24" fill="none">
                    <path d="M14 2H6A2 2 0 0 0 4 4V20A2 2 0 0 0 6 22H18A2 2 0 0 0 20 20V8Z" stroke="currentColor" stroke-width="2" />
                    <polyline points="14,2 14,8 20,8" stroke="currentColor" stroke-width="2" />
                    <line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="2" />
                    <line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="2" />
                </svg>
            </div>
            <div class="stat-number" id="number-total">8</div>
        </div>
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Upcoming Interviews</span>
                <svg class="stat-icon" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2" />
                    <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2" />
                    <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2" />
                    <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2" />
                </svg>
            </div>
            <div class="stat-number" id="number-upcoming">1</div>
            <div class="stat-description">This week</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-title">Pending Confirmations</span>
                <svg class="stat-icon" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
                    <path d="M12 6V12L16 14" stroke="currentColor" stroke-width="2" />
                </svg>
            </div>
            <div class="stat-number" id="number-pending">1</div>
            <div class="stat-description">Awaiting response</div>
        </div>
    </div>

    <div class="interviews-section">
        <div class="section-header">
            <h2 class="section-title">Upcoming Interviews</h2>
            <input type="text" id="searchInput" class="search-input" placeholder="Search interviews...">
        </div>
        <div id="interviewList">
        </div>
        <div id="pagination">
        </div>
    </div>
</div>
<script>
    document.addEventListener('DOMContentLoaded', () => {
    let interviews = [
    @foreach (var interview in Model)
    {
        <text>
        {
				id: @interview.InterviewId,
				title: "@interview.Position Interview",
				company: "@interview.Hiring.HiringNavigation.Company.Name",
				interviewer: "@interview.Hiring.HiringNavigation.FirstName @interview.Hiring.HiringNavigation.LastName",
				date: "@interview.Date.ToString("yyyy-MM-dd")",
				time: "@interview.Time",
				status: "@interview.Status",
				meetLink : "@interview.LinkMeet"
        },
        </text>
    }
        ];

		const total = document.getElementById('number-total');
		total.textContent = interviews.length;
		const upcoming = document.getElementById('number-upcoming');
        upcoming.textContent = interviews.filter(i => i.status === 'Active').length;
		const pending = document.getElementById('number-pending');
        pending.textContent = interviews.filter(i => i.status === 'Pending').length;

        const interviewListEl = document.getElementById('interviewList');
        const paginationEl = document.getElementById('pagination');
        const searchInputEl = document.getElementById('searchInput');

        let currentPage = 1;
        const itemsPerPage = 3;
        let filteredInterviews = interviews;

        const getInterviewStatus = (interview) => {
            const [datePart, timePart, ampm] = interview.time.split(/([0-9]{2}:[0-9]{2})\s(AM|PM)/).filter(Boolean);
            const [hours, minutes] = datePart.split(':').map(Number);
            let normalizedHours = hours;
            if (ampm === 'PM' && hours !== 12) {
                normalizedHours += 12;
            }
            if (ampm === 'AM' && hours === 12) {
                normalizedHours = 0;
            }

            const interviewDateTime = new Date(`${interview.date}T${String(normalizedHours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:00`);
            const now = new Date();
            return interviewDateTime < now ? 'completed' : 'pending';
        };

        const renderInterviewItem = (interview) => {
            const status = interview.status;
            const meetButton = status === 'Active' ?
                `<button class="join-meet-btn" onclick="window.open('${interview.meetLink}', '_blank')">Join Meet</button>` : '';

            const iconPath = `
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M17 21V19A4 4 0 0 0 13 15H5A4 4 0 0 0 1 19V21" stroke="currentColor" stroke-width="2" />
                    <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2" />
                    <path d="M23 21V19A4 4 0 0 0 16 15.13" stroke="currentColor" stroke-width="2" />
                    <path d="M16 3.13A4 4 0 0 1 16 11" stroke="currentColor" stroke-width="2" />
                </svg>
            `;

            return `
                <div class="interview-card">
                    <div class="interview-icon">
                        ${iconPath}
                    </div>
                    <div class="interview-content">
                        <div class="interview-info">
                            <h3 class="interview-title">${interview.title}</h3>
                            <div class="interview-company">${interview.company}</div>
                            <div class="interview-interviewer">${interview.interviewer}</div>
                        </div>
                        <div class="interview-meta">
                            <div class="interview-date">${interview.date}</div>
                            <div class="interview-time">${interview.time}</div>
                            <span class="interview-status status-${status}">${status}</span>
                            ${meetButton}
                        </div>
                    </div>
                </div>
            `;
        };

        const renderInterviews = () => {
            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;
            const interviewsToRender = filteredInterviews.slice(startIndex, endIndex);

            interviewListEl.innerHTML = interviewsToRender.map(renderInterviewItem).join('');
            renderPagination();
        };

        const renderPagination = () => {
            const totalPages = Math.ceil(filteredInterviews.length / itemsPerPage);
            paginationEl.innerHTML = '';

            if (totalPages <= 1) return;

            const paginationContainer = document.createElement('div');
            paginationContainer.className = 'pagination-container';

            for (let i = 1; i <= totalPages; i++) {
                const button = document.createElement('button');
                button.className = `pagination-button ${i === currentPage ? 'active' : ''}`;
                button.textContent = i;
                button.addEventListener('click', () => {
                    currentPage = i;
                    renderInterviews();
                });
                paginationContainer.appendChild(button);
            }
            paginationEl.appendChild(paginationContainer);
        };

        searchInputEl.addEventListener('input', (e) => {
            const searchTerm = e.target.value.toLowerCase();
            filteredInterviews = interviews.filter(item =>
                item.title.toLowerCase().includes(searchTerm) ||
                item.company.toLowerCase().includes(searchTerm) ||
                item.interviewer.toLowerCase().includes(searchTerm)
            );
            currentPage = 1;
            renderInterviews();
        });

        renderInterviews();
    });
</script>
@section Styles {
	<link rel="stylesheet" href="~/css/UserDashBoard.css" />
}