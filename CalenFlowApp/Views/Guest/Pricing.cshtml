@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<section class="hero">
    <div class="hero-content">
        <div class="hero-badge">💰 Flexible Pricing</div>
        <h1>Choose the Perfect Plan<br>for Your Team</h1>
        <p>Start free and scale as you grow. All plans include our core features with advanced AI assistance.</p>

        <div class="billing-toggle">
            <span>Monthly</span>
            <div class="toggle-container">
                <div class="toggle-switch" id="billingToggle" onclick="toggleBilling()">
                    <div class="toggle-slider"></div>
                </div>
                <span>Yearly</span>
                <span class="save-badge">Save up to 25%</span>
            </div>
        </div>

        <div class="trust-indicators">
            <div class="trust-item">
                <div class="trust-icon">👥</div>
                <div class="trust-number">50,000+</div>
                <div class="trust-label">Users<br>Trust Calendflow</div>
            </div>
            <div class="trust-item">
                <div class="trust-icon">📅</div>
                <div class="trust-number">1M+</div>
                <div class="trust-label">Interviews<br>Successfully Scheduled</div>
            </div>
            <div class="trust-item">
                <div class="trust-icon">⭐</div>
                <div class="trust-number">4.9/5</div>
                <div class="trust-label">Rating<br>Customer Satisfaction</div>
            </div>
        </div>
    </div>
</section>
<section class="section promotions">
    <div class="container">
        <div class="section-badge">🎁 Limited Time Offers</div>
        <h2 class="section-title">Current Promotions</h2>
        <p class="section-subtitle">Take advantage of these limited-time offers</p>

        <div class="promotions-grid">
            <div class="promo-card" onclick="applyPromo('NEWYEAR50')">
                <div class="promo-icon">🎉</div>
                <h3>New Year Special</h3>
                <p>Get 50% off your first 3 months on any paid plan</p>
                <div class="promo-code">NEWYEAR50</div>
                <div class="promo-expiry">Expires January 31, 2025</div>
            </div>
            <div class="promo-card" onclick="applyPromo('STARTUP2025')">
                <div class="promo-icon">🚀</div>
                <h3>Startup Discount</h3>
                <p>Verified startups get 6 months free on Business plan</p>
                <div class="promo-code">STARTUP2025</div>
                <div class="promo-expiry">Limited time offer</div>
            </div>
            <div class="promo-card" onclick="applyPromo('EDU40')">
                <div class="promo-icon">🎓</div>
                <h3>Education Discount</h3>
                <p>Educational institutions get 40% off all plans</p>
                <div class="promo-code">EDU40</div>
                <div class="promo-expiry">Ongoing offer</div>
            </div>
        </div>
    </div>
</section>
<section class="section">
    <div class="pricing-container">
        <div class="pricing-wrapper" id="pricingWrapper">
            <div class="pricing-page">
                <div class="pricing-card">
                    <div class="pricing-header">
                        <h3>Free</h3>
                        <div class="pricing-price">
                            <span class="currency">$</span>0
                            <span class="period">/month</span>
                        </div>
                        <p class="pricing-description">Perfect for individuals and small teams getting started</p>
                        <a href="#" class="pricing-cta secondary" onclick="selectPlan('free')">Get Started Free →</a>
                    </div>
                    <ul class="pricing-features">
                        <li class="included">Up to 10 interviews/month</li>
                        <li class="included">Basic calendar sync</li>
                        <li class="included">Email notifications</li>
                        <li class="included">Standard templates</li>
                        <li class="included">Basic reporting</li>
                        <li class="not-included">AI scheduling assistant</li>
                        <li class="not-included">Custom branding</li>
                        <li class="not-included">Team collaboration</li>
                        <li class="not-included">Advanced analytics</li>
                        <li class="not-included">Priority support</li>
                    </ul>
                </div>

                <div class="pricing-card">
                    <div class="pricing-badge">Most Popular</div>
                    <div class="pricing-header">
                        <h3>Pro</h3>
                        <div class="pricing-price">
                            <span class="currency">$</span><span id="proPrice">19</span>
                            <span class="period">/month</span>
                        </div>
                        <p class="pricing-description">Ideal for growing teams and HR professionals</p>
                        <a href="#" class="pricing-cta primary" onclick="selectPlan('pro')">Start Pro Trial →</a>
                    </div>
                    <ul class="pricing-features">
                        <li class="included">Unlimited interviews</li>
                        <li class="included">Advanced calendar sync</li>
                        <li class="included">Multi-channel notifications</li>
                        <li class="included">Custom templates</li>
                        <li class="included">Advanced reporting</li>
                        <li class="included">AI scheduling assistant</li>
                        <li class="included">Custom branding</li>
                        <li class="included">Team collaboration (up to 5 users)</li>
                        <li class="included">Advanced analytics</li>
                        <li class="included">Priority support</li>
                    </ul>
                </div>
            </div>

            <div class="pricing-page">
                <div class="pricing-card">
                    <div class="pricing-badge value">Best Value</div>
                    <div class="pricing-header">
                        <h3>Business</h3>
                        <div class="pricing-price">
                            <span class="currency">$</span><span id="businessPrice">49</span>
                            <span class="period">/month</span>
                        </div>
                        <p class="pricing-description">Perfect for medium-sized businesses and teams</p>
                        <a href="#" class="pricing-cta secondary" onclick="selectPlan('business')">Start Business Trial →</a>
                    </div>
                    <ul class="pricing-features">
                        <li class="included">Unlimited interviews</li>
                        <li class="included">Advanced calendar sync</li>
                        <li class="included">Multi-channel notifications</li>
                        <li class="included">Custom templates</li>
                        <li class="included">Advanced reporting</li>
                        <li class="included">AI scheduling assistant</li>
                        <li class="included">Custom branding</li>
                        <li class="included">Team collaboration (up to 25 users)</li>
                        <li class="included">Advanced analytics</li>
                        <li class="included">Priority support</li>
                    </ul>
                </div>

                <div class="pricing-card">
                    <div class="pricing-badge custom">Custom</div>
                    <div class="pricing-header">
                        <h3>Enterprise</h3>
                        <div class="pricing-price">Custom</div>
                        <p class="pricing-description">Tailored solutions for large organizations</p>
                        <a href="#" class="pricing-cta secondary" onclick="contactSales()">Contact Sales →</a>
                    </div>
                    <ul class="pricing-features">
                        <li class="included">Unlimited everything</li>
                        <li class="included">Advanced integrations</li>
                        <li class="included">White-label solution</li>
                        <li class="included">Custom workflows</li>
                        <li class="included">Enterprise reporting</li>
                        <li class="included">Advanced AI features</li>
                        <li class="included">Complete customization</li>
                        <li class="included">Unlimited users</li>
                        <li class="included">Custom analytics</li>
                        <li class="included">Dedicated support</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="pricing-nav">
            <button class="pricing-arrow" id="prevArrow" onclick="previousPricingPage()">‹</button>
            <div class="pricing-dots">
                <div class="pricing-dot active" onclick="goToPricingPage(0)"></div>
                <div class="pricing-dot" onclick="goToPricingPage(1)"></div>
            </div>
            <button class="pricing-arrow" id="nextArrow" onclick="nextPricingPage()">›</button>
        </div>
    </div>
</section>
<section class="section enterprise-features">
    <div class="container">
        <div class="section-badge">🏢 Enterprise Solutions</div>
        <h2 class="section-title">Built for Large Organizations</h2>
        <p class="section-subtitle">Get enterprise-grade features, security, and support tailored to your organization's needs.</p>

        <div class="enterprise-grid">
            <div class="enterprise-card">
                <div class="enterprise-icon">🛡️</div>
                <h3>Enterprise Security</h3>
                <p>SOC 2 Type II, GDPR compliance, and advanced security controls</p>
            </div>
            <div class="enterprise-card">
                <div class="enterprise-icon">👨‍💼</div>
                <h3>Dedicated Success Manager</h3>
                <p>Personal account manager to ensure your success</p>
            </div>
            <div class="enterprise-card">
                <div class="enterprise-icon">⚡</div>
                <h3>Custom Integrations</h3>
                <p>Build custom integrations with our dedicated API support</p>
            </div>
            <div class="enterprise-card">
                <div class="enterprise-icon">📊</div>
                <h3>Advanced Reporting</h3>
                <p>Custom dashboards and enterprise-grade analytics</p>
            </div>
            <div class="enterprise-card">
                <div class="enterprise-icon">🎧</div>
                <h3>24/7 Premium Support</h3>
                <p>Priority support with guaranteed response times</p>
            </div>
            <div class="enterprise-card">
                <div class="enterprise-icon">🏢</div>
                <h3>On-Premise Deployment</h3>
                <p>Deploy Calendflow on your own infrastructure if needed</p>
            </div>
        </div>
    </div>
</section>
<section class="section faq">
    <div class="container">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <p class="section-subtitle">Got questions? We've got answers.</p>

        <div class="faq-list">
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFAQ(this)">
                    Can I switch plans anytime?
                </button>
                <div class="faq-answer">
                    <p>Yes, you can upgrade or downgrade your plan at any time. Changes will be reflected in your next billing cycle.</p>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFAQ(this)">
                    What happens if I exceed my interview limit?
                </button>
                <div class="faq-answer">
                    <p>For the Free plan, you'll need to upgrade to continue scheduling. Paid plans have no limits.</p>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFAQ(this)">
                    Do you offer refunds?
                </button>
                <div class="faq-answer">
                    <p>Yes, we offer a 30-day money-back guarantee on all paid plans.</p>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFAQ(this)">
                    Is there a setup fee?
                </button>
                <div class="faq-answer">
                    <p>No, there are no setup fees or hidden costs. You only pay for your subscription.</p>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFAQ(this)">
                    How does the AI assistant work?
                </button>
                <div class="faq-answer">
                    <p>Our AI learns from your scheduling patterns and preferences to suggest optimal meeting times and handle conflicts automatically.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    let isYearly = false;
    const monthlyPrices = { pro: 19, business: 49 };
    const yearlyPrices = { pro: 14, business: 37 };

    function toggleBilling() {
        const toggle = document.getElementById('billingToggle');
        const proPrice = document.getElementById('proPrice');
        const businessPrice = document.getElementById('businessPrice');

        isYearly = !isYearly;
        toggle.classList.toggle('active');

        if (isYearly) {
            proPrice.textContent = yearlyPrices.pro;
            businessPrice.textContent = yearlyPrices.business;
        } else {
            proPrice.textContent = monthlyPrices.pro;
            businessPrice.textContent = monthlyPrices.business;
        }
    }

    function applyPromo(code) {
        const promos = {
            'NEWYEAR50': 'New Year Special: 50% off first 3 months applied!',
            'STARTUP2025': 'Startup Discount: 6 months free on Business plan applied!',
            'EDU40': 'Education Discount: 40% off all plans applied!'
        };

        alert(promos[code] || 'Promo code applied!');
    }

    function selectPlan(plan) {
        const planMessages = {
            'free': 'Welcome to Calendflow Free! You can start scheduling interviews right away.',
            'pro': 'Starting your Pro trial! You\'ll have access to all Pro features for 14 days.',
            'business': 'Starting your Business trial! You\'ll have access to all Business features for 14 days.'
        };

        alert(planMessages[plan] || 'Plan selected!');
    }

    function contactSales() {
        alert('Our sales team will contact you within 24 hours to discuss your enterprise needs!');
    }

    function toggleFAQ(button) {
        const answer = button.nextElementSibling;
        const isActive = button.classList.contains('active');

        document.querySelectorAll('.faq-question').forEach(q => {
            q.classList.remove('active');
            q.nextElementSibling.classList.remove('active');
        });

        if (!isActive) {
            button.classList.add('active');
            answer.classList.add('active');
        }
    }

    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        });
    });

    window.addEventListener('scroll', function() {
        const header = document.querySelector('.header');
        if (window.scrollY > 100) {
            header.style.background = 'rgba(255, 255, 255, 0.98)';
        } else {
            header.style.background = 'rgba(255, 255, 255, 0.95)';
        }
    });

    document.querySelectorAll('.promo-card, .enterprise-card').forEach(card => {
        card.addEventListener('mouseenter', function() {
            if (this.classList.contains('promo-card')) {
                this.style.transform = 'translateY(-5px)';
                this.style.borderColor = '#3b82f6';
                this.style.background = 'linear-gradient(135deg, #dbeafe, #f0f9ff)';
            } else {
                this.style.transform = 'translateY(-5px) scale(1.02)';
            }
        });

        card.addEventListener('mouseleave', function() {
            if (this.classList.contains('promo-card')) {
                this.style.transform = 'translateY(0)';
                this.style.borderColor = '#e5e7eb';
                this.style.background = 'white';
            } else {
                this.style.transform = 'translateY(0) scale(1)';
            }
        });
    });

    let currentPricingPage = 0;
    const totalPricingPages = 2;

    function updatePricingDisplay() {
        const wrapper = document.getElementById('pricingWrapper');
        const dots = document.querySelectorAll('.pricing-dot');
        const prevArrow = document.getElementById('prevArrow');
        const nextArrow = document.getElementById('nextArrow');

        wrapper.style.transform = `translateX(-${currentPricingPage * 100}%)`;

        dots.forEach((dot, index) => {
            dot.classList.toggle('active', index === currentPricingPage);
        });

        prevArrow.disabled = currentPricingPage === 0;
        nextArrow.disabled = currentPricingPage === totalPricingPages - 1;
    }

    function nextPricingPage() {
        if (currentPricingPage < totalPricingPages - 1) {
            currentPricingPage++;
            updatePricingDisplay();
        }
    }

    function previousPricingPage() {
        if (currentPricingPage > 0) {
            currentPricingPage--;
            updatePricingDisplay();
        }
    }

    function goToPricingPage(pageIndex) {
        currentPricingPage = pageIndex;
        updatePricingDisplay();
    }

    document.addEventListener('DOMContentLoaded', function() {
        updatePricingDisplay();
    });
</script>
@section Styles {
    <link rel="stylesheet" href="~/css/GuestPricing.css" />
}