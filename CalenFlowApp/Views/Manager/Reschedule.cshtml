@model List<BusinessObjects.Models.Reschedule>
@Html.AntiForgeryToken()
@{
	Layout = "~/Views/Shared/_LayoutSidebarManager.cshtml";
}
<div class="container">
    <div class="page-header">
        <h1 class="page-title">Reschedule Requests</h1>
        <p class="page-subtitle">Review and manage interview reschedule requests</p>
    </div>

    <div class="requests-list" id="requestsList">
    </div>

    <div class="empty-state" id="emptyState" style="display: none;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12,6 12,12 16,14" />
        </svg>
        <h3>No Reschedule Requests</h3>
        <p>All interview schedules are confirmed. New reschedule requests will appear here.</p>
    </div>

    <div class="pagination" id="pagination" style="display: none;">
    </div>
</div>

<script>
        class RescheduleRequestsManager {
        constructor() {
            this.currentPage = 1;
            this.itemsPerPage = 3;
            this.requests = [
                @foreach (var interview in Model)
                {
                    <text>
                        {
							id: @interview.CandidateId,
                            candidateName: "@interview.Candidate.CandidateNavigation.FirstName" + " @interview.Candidate.CandidateNavigation.LastName",
							position: "",
							originalDate: "@interview.OrginalDate.ToString("yyyy-MM-dd h:mm tt")",
							requestedDate: "@interview.RescheduleDate.ToString("yyyy-MM-dd h:mm tt")",
							reason: "@interview.Reason",
							status: "pending"
                        },
                    </text>
                }
            ];
            this.init();
        }

        init() {
            this.renderRequests();
            this.renderPagination();
        }

        renderRequests() {
            const requestsList = document.getElementById('requestsList');
            const emptyState = document.getElementById('emptyState');

            const pendingRequests = this.requests;

            if (pendingRequests.length === 0) {
                requestsList.style.display = 'none';
                emptyState.style.display = 'block';
                document.getElementById('pagination').style.display = 'none';
                return;
            }

            requestsList.style.display = 'flex';
            emptyState.style.display = 'none';

            const startIndex = (this.currentPage - 1) * this.itemsPerPage;
            const endIndex = startIndex + this.itemsPerPage;
            const currentPageRequests = pendingRequests.slice(startIndex, endIndex);

            requestsList.innerHTML = currentPageRequests.map(request => this.renderRequestCard(request)).join('');
        }

        renderRequestCard(request) {
            return `
                <div class="request-card" data-id="${request.id}">
                    <div class="candidate-header">
                        <div class="candidate-info">
                            <h3>${request.candidateName}</h3>
                            <div class="candidate-position">${request.position}</div>

                            <div class="schedule-details">
                                <div class="schedule-item">
                                    <span class="schedule-label">Original:</span>
                                    <span class="schedule-time">${request.originalDate}</span>
                                </div>
                                <div class="schedule-item">
                                    <span class="schedule-label">Requested:</span>
                                    <span class="schedule-time">${request.requestedDate}</span>
                                </div>
                            </div>
                        </div>

                        <div class="action-buttons">
                            <button class="btn btn-approve" onclick="approveRequest(${request.id})">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M22 11.08V12A10 10 0 1 1 5.93 7.01"/>
                                    <polyline points="22,4 12,14.01 9,11.01"/>
                                </svg>
                                Approve
                            </button>
                            <button class="btn btn-reject" onclick="rejectRequest(${request.id})">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="18" y1="6" x2="6" y2="18"/>
                                    <line x1="6" y1="6" x2="18" y2="18"/>
                                </svg>
                                Reject
                            </button>
                        </div>
                    </div>

                    <div class="reason-section">
                        <div class="reason-label">Reason:</div>
                        <div class="reason-text">${request.reason}</div>
                    </div>
                </div>
            `;
        }

        renderPagination() {
            const pendingRequests = this.requests;
            const totalPages = Math.ceil(pendingRequests.length / this.itemsPerPage);

            if (totalPages <= 1) {
                document.getElementById('pagination').style.display = 'none';
                return;
            }

            document.getElementById('pagination').style.display = 'flex';

            const startItem = (this.currentPage - 1) * this.itemsPerPage + 1;
            const endItem = Math.min(this.currentPage * this.itemsPerPage, pendingRequests.length);

            const pages = [];
            for (let i = 1; i <= totalPages; i++) {
                pages.push(i);
            }

            document.getElementById('pagination').innerHTML = `
                <div class="pagination-info">
                    Showing ${startItem}-${endItem} of ${pendingRequests.length} requests
                </div>

                <div class="pagination-controls">
                    <button class="pagination-btn"
                            onclick="changePage(${this.currentPage - 1})"
                            ${this.currentPage === 1 ? 'disabled' : ''}>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="15,18 9,12 15,6"/>
                        </svg>
                    </button>

                    ${pages.map(page => `
                        <button class="pagination-btn ${page === this.currentPage ? 'active' : ''}"
                                onclick="changePage(${page})">
                            ${page}
                        </button>
                    `).join('')}

                    <button class="pagination-btn"
                            onclick="changePage(${this.currentPage + 1})"
                            ${this.currentPage === totalPages ? 'disabled' : ''}>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="9,18 15,12 9,6"/>
                        </svg>
                    </button>
                </div>
            `;
        }

        changePage(page) {
            const pendingRequests = this.requests;
            const totalPages = Math.ceil(pendingRequests.length / this.itemsPerPage);

            if (page >= 1 && page <= totalPages) {
                this.currentPage = page;
                this.renderRequests();
                this.renderPagination();
            }
        }
       convertToDotNetDateTime(dateString) {
      // dateString: "2025-09-24 10:00 AM"
      const [datePart, timePart, modifier] = dateString.split(" ");
      let [year, month, day] = datePart.split("-");
      let [hours, minutes] = timePart.split(":");

      hours = parseInt(hours, 10);

      if (modifier === "PM" && hours < 12) {
        hours += 12;
      }
      if (modifier === "AM" && hours === 12) {
        hours = 0;
      }

      return `${year}-${month}-${day}T${String(hours).padStart(2,"0")}:${minutes}:00`;
    }

    approveRequest(requestId) {
        const request = this.requests.find(r => r.id === requestId);
        if (request) {
            fetch('/Manager/ResponseRequestMeeting', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ CandidateId: Number(requestId), HiringId: 3, IsAccepted: true, newDate: this.convertToDotNetDateTime(request.requestedDate) })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const card = document.querySelector(`.request-card[data-id="${requestId}"]`);
                    if (card) {
                        card.classList.add("fade-out");
                        setTimeout(() => {
                            this.requests = this.requests.filter(r => r.id !== requestId);
                            const pendingRequests = this.requests.filter(r => r.id !== requestId);
                            const totalPages = Math.ceil(pendingRequests.length / this.itemsPerPage);
                            if (this.currentPage > totalPages && totalPages > 0) {
                                this.currentPage = totalPages;
                            }
                            this.renderRequests();
                            this.renderPagination();
                            this.showToast(`Reschedule request for ${request.candidateName} approved successfully!`, "success");
                        }, 400);
                    }
                } else {
                this.showToast(data.message, 'error');
                }
            })
            .catch(err => {
                console.error("Error updating status:", err);
                this.showToast("Something went wrong!", "error");
            });
        }
    }

    rejectRequest(requestId) {
        const request = this.requests.find(r => r.id === requestId);
        if (request) {
            fetch('/Manager/ResponseRequestMeeting', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ CandidateId: Number(requestId), HiringId: 3, IsAccepted: false, newDate: this.convertToDotNetDateTime(request.requestedDate) })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const card = document.querySelector(`.request-card[data-id="${requestId}"]`);
                    if (card) {
                        card.classList.add("fade-out");
                        setTimeout(() => {
                            this.requests = this.requests.filter(r => r.id !== requestId);
                            const pendingRequests = this.requests.filter(r => r.id !== requestId);
                            const totalPages = Math.ceil(pendingRequests.length / this.itemsPerPage);
                            if (this.currentPage > totalPages && totalPages > 0) {
                                this.currentPage = totalPages;
                            }
                            this.renderRequests();
                            this.renderPagination();
                            this.showToast(`Reschedule request for ${request.candidateName} rejected.`, "error");
                        }, 400);
                    }
                } else {
                this.showToast(data.message, 'error');
                }
            })
            .catch(err => {
                console.error("Error updating status:", err);
                this.showToast("Something went wrong!", "error");
            });
        }
    }


        showToast(message, type = 'success') {
                        const existingToast = document.querySelector('.toast');
            if (existingToast) {
                existingToast.remove();
            }

            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.textContent = message;

            document.body.appendChild(toast);

                        setTimeout(() => {
                toast.classList.add('show');
            }, 100);

                        setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => {
                    if (document.body.contains(toast)) {
                        document.body.removeChild(toast);
                    }
                }, 300);
            }, 4000);
        }
    }

        function approveRequest(requestId) {
        if (window.rescheduleManager) {
            window.rescheduleManager.approveRequest(requestId);
        }
    }

    function rejectRequest(requestId) {
        if (window.rescheduleManager) {
            window.rescheduleManager.rejectRequest(requestId);
        }
    }

    function changePage(page) {
        if (window.rescheduleManager) {
            window.rescheduleManager.changePage(page);
        }
    }

        document.addEventListener('DOMContentLoaded', function() {
        window.rescheduleManager = new RescheduleRequestsManager();
    });
</script>
@section Styles {
	<link rel="stylesheet" href="~/css/ManagerReschedule.css" />
}